##############################################
# VEX Backend environment variables
#+ Copy this file to `.env` and fill secrets
##############################################

# Async SQLAlchemy database URL (asyncpg)
DATABASE_URL=postgresql+asyncpg://vex:password@localhost:5432/vex

# Redis URL (used for caching, sessions)
REDIS_URL=redis://localhost:6379/0

# JWT configuration
# Use a long, random secret (min 32 chars)
JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Stripe keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public backend URL (used for webhook redirect/links)
BACKEND_URL=http://localhost:8000

# Notes:
# - Ensure DATABASE_URL, REDIS_URL, JWT_SECRET, and STRIPE_* are set in production.
