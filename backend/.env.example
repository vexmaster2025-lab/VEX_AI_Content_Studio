##############################################
# VEX Backend environment variables
#+ Copy this file to `.env` and fill secrets
##############################################

# Application environment
ENV=development
LOG_LEVEL=INFO

# Async SQLAlchemy database URL (asyncpg)
DATABASE_URL=postgresql+asyncpg://vex:password@localhost:5432/vex

# Redis URL (used for caching, sessions)
REDIS_URL=redis://localhost:6379/0

# CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Public backend URL
BACKEND_URL=http://localhost:8000

# JWT configuration. Use a unique 32+ character secret in every environment.
JWT_SECRET=dev_only_change_this_secret_32_chars_minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Stripe billing. Leave blank for local auth/content work; required for checkout/webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Notes:
# - Ensure DATABASE_URL, REDIS_URL, JWT_SECRET, and BACKEND_URL are set.
# - For production, copy this file to .env and set secure values.
