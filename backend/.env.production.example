# VEX Backend - Production environment variables (copy to .env and fill securely)
# DATABASE
DATABASE_URL=postgresql+asyncpg://vex:strongpassword@db-host:5432/vexdb

# REDIS
REDIS_URL=redis://redis-host:6379/0

# JWT (use a secure random 32+ character secret)
JWT_SECRET=replace_with_secure_random_>=32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Stripe (LIVE keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_live_...

# Public URL reachable by Stripe (https)
BACKEND_URL=https://api.yourdomain.com

# CORS - comma-separated list of allowed origins for production (no wildcard)
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# Logging & monitoring
LOG_LEVEL=INFO
SENTRY_DSN=

# SQLAlchemy / DB tuning (optional)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Misc
# Ensure to set these in your deployment environment - don't commit secrets

